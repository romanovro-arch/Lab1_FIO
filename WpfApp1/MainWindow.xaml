<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Проект 1: Треугольник" Height="350" Width="400">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Сторона A:" Grid.Row="0" Grid.Column="0" Margin="0,0,10,5"/>
        <TextBox x:Name="TxtSideA" Grid.Row="0" Grid.Column="1" Margin="0,0,0,5"/>

        <TextBlock Text="Сторона B:" Grid.Row="1" Grid.Column="0" Margin="0,0,10,5"/>
        <TextBox x:Name="TxtSideB" Grid.Row="1" Grid.Column="1" Margin="0,0,0,5"/>

        <TextBlock Text="Сторона C:" Grid.Row="2" Grid.Column="0" Margin="0,0,10,5"/>
        <TextBox x:Name="TxtSideC" Grid.Row="2" Grid.Column="1" Margin="0,0,0,5"/>

        <Button Content="Вычислить и нарисовать" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,10,0,10" Click="BtnCalculate_Click"/>

        <TextBlock x:Name="TxtResult" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" FontWeight="Bold" Margin="0,0,0,10"/>

        <Border Grid.Row="0" Grid.RowSpan="5" Grid.Column="2" Width="100" Height="100" BorderBrush="Black" BorderThickness="1" Margin="20,0,0,0" VerticalAlignment="Top">
            <Canvas x:Name="DrawingCanvas" Width="100" Height="100" Background="LightGray"/>
        </Border>
    </Grid>
</Window>